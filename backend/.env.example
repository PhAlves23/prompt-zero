# Copie para .env e preencha os segredos. Nunca commite .env.
#
# Obrigatório (app + auth): DATABASE_URL, JWT_*, ENCRYPTION_SECRET.
# Em produção o bootstrap valida JWT_* , ENCRYPTION_SECRET e DATABASE_URL.

PORT=3001
NODE_ENV=development
# Origem do Next (CORS e URLs de retorno). Em produção: https://seu-dominio-frontend
FRONTEND_URL=http://localhost:3000
# Locale: Stripe return URLs e segmento do path após OAuth (/{locale}/auth/oauth-callback)
BILLING_UI_LOCALE=pt-BR

# Stripe (billing)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PRO=
# STRIPE_PRICE_TEAM=

# Google OAuth (opcional — ativa GET /api/v1/auth/google e callback)
# No Google Cloud Console, o "Authorized redirect URI" deve ser IGUAL a GOOGLE_CALLBACK_URL.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# GitHub OAuth (opcional — ativa GET /api/v1/auth/github e callback)
# Use uma GitHub OAuth App (Developer settings → OAuth Apps). Client ID + Secret aqui.
# "Authorization callback URL" no GitHub = mesmo valor que GITHUB_CALLBACK_URL (host/porta certos).
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/auth/github/callback

DATABASE_URL=postgresql://postgres:postgres@localhost:5434/promptzero
JWT_ACCESS_SECRET=replace_with_strong_access_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ENCRYPTION_SECRET=replace_with_strong_encryption_secret_min_32_chars

# LLM resilience (optional)
LLM_MAX_RETRIES=2
LLM_BACKOFF_MS=300
LLM_TIMEOUT_MS=30000
LLM_CIRCUIT_FAILURE_THRESHOLD=3
LLM_CIRCUIT_COOLDOWN_MS=30000

# Metrics/Prometheus (optional)
METRICS_ENABLED=true
METRICS_PATH=/metrics

# Redis (optional, used for A/B experiments real-time counters)
REDIS_URL=redis://localhost:6379

# MinIO Configuration
MINIO_ENDPOINT=<MINIO_ENDPOINT>
MINIO_PORT=9000
MINIO_ROOT_USER=<MINIO_ROOT_USER>
MINIO_ROOT_PASSWORD=<MINIO_ROOT_PASSWORD>
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=prompt-zero
MINIO_PUBLIC_URL=<MINIO_PUBLIC_URL>

# Observability - Tracing (OpenTelemetry + Tempo)
TRACING_ENABLED=true
SERVICE_NAME=promptzero-backend
SERVICE_VERSION=1.0.0
TEMPO_ENDPOINT=http://localhost:4318
# For production with OTel Collector:
# TEMPO_ENDPOINT=http://otel-collector:4318

# Observability - Logs (Loki)
# false em local se nao tiver Loki na porta 3100 (evita ECONNREFUSED no arranque).
# Com stack: ver observability/README.md ou observability/start-observability.sh
LOKI_ENABLED=false
LOKI_ENDPOINT=http://localhost:3100
LOG_LEVEL=info

# Observability - Metrics (Prometheus OTLP - Optional, for push-based metrics)
PROMETHEUS_OTLP_ENDPOINT=http://localhost:4318
# Note: Prometheus primarily scrapes metrics from /api/metrics endpoint
# OTLP endpoint is for additional OpenTelemetry metrics if needed

