PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/promptzero
JWT_ACCESS_SECRET=replace_with_strong_access_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ENCRYPTION_SECRET=replace_with_strong_encryption_secret_min_32_chars

# LLM resilience (optional)
LLM_MAX_RETRIES=2
LLM_BACKOFF_MS=300
LLM_TIMEOUT_MS=30000
LLM_CIRCUIT_FAILURE_THRESHOLD=3
LLM_CIRCUIT_COOLDOWN_MS=30000

# Metrics/Prometheus (optional)
METRICS_ENABLED=true
METRICS_PATH=/metrics

# Redis (optional, used for A/B experiments real-time counters)
REDIS_URL=redis://localhost:6379

# MinIO Configuration
MINIO_ENDPOINT=<MINIO_ENDPOINT>
MINIO_PORT=9000
MINIO_ROOT_USER=<MINIO_ROOT_USER>
MINIO_ROOT_PASSWORD=<MINIO_ROOT_PASSWORD>
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=prompt-zero
MINIO_PUBLIC_URL=<MINIO_PUBLIC_URL>

# Observability - Tracing (OpenTelemetry + Tempo)
TRACING_ENABLED=true
SERVICE_NAME=promptzero-backend
SERVICE_VERSION=1.0.0
TEMPO_ENDPOINT=http://localhost:4318
# For production with OTel Collector:
# TEMPO_ENDPOINT=http://otel-collector:4318

# Observability - Logs (Loki)
LOKI_ENABLED=true
LOKI_ENDPOINT=http://localhost:3100
LOG_LEVEL=info

# Observability - Metrics (Prometheus OTLP - Optional, for push-based metrics)
PROMETHEUS_OTLP_ENDPOINT=http://localhost:4318
# Note: Prometheus primarily scrapes metrics from /api/metrics endpoint
# OTLP endpoint is for additional OpenTelemetry metrics if needed

