generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Language {
  pt
  en
  es
}

enum VariableType {
  text
  textarea
  select
}

enum ProviderType {
  openai
  anthropic
  google
  openrouter
  platform_api
}

enum ExperimentStatus {
  running
  stopped
}

enum ExperimentVariant {
  A
  B
}

enum SubscriptionTier {
  free
  pro
  team
  enterprise
}

enum SubscriptionStatus {
  active
  canceled
  past_due
  trialing
  incomplete
  incomplete_expired
  unpaid
}

enum DatasetRunStatus {
  pending
  running
  completed
  failed
}

enum WorkspaceRole {
  owner
  admin
  editor
  viewer
}

enum AuditAction {
  create
  update
  delete
}

model User {
  id                 String   @id @default(uuid())
  name               String
  email              String   @unique
  passwordHash       String
  refreshTokenHash   String?
  openaiApiKeyEnc    String?
  anthropicApiKeyEnc String?
  avatarUrl          String?
  googleId           String?  @unique
  githubId           String?  @unique
  samlNameId         String?  @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspaces Workspace[]
  prompts    Prompt[]
  tags       Tag[]
  executions Execution[]
  refreshSessions RefreshTokenSession[]
  providerCredentials ProviderCredential[]
  experiments PromptExperiment[]
  subscription      Subscription?
  usageMetrics      UsageMetric[]
  datasets          Dataset[]
  evaluationCriteria EvaluationCriteria[]
  workspaceMembers  WorkspaceMember[]
  workspaceInvitesSent WorkspaceMember[] @relation("WorkspaceInviter")
  auditLogs         AuditLog[]
  webhooks          Webhook[]
  platformApiKeys   PlatformApiKey[]
  traceRuns         TraceRun[]
  comments          Comment[]
  mentions          UserMention[]
  invoices          Invoice[]
  cacheMetrics      CacheMetric[]
}

model Workspace {
  id               String   @id @default(uuid())
  name             String
  description      String?
  color            String   @default("#6366F1")
  isDefault        Boolean  @default(false)
  userId           String
  cacheEnabled     Boolean  @default(false)
  cacheTtlSeconds  Int      @default(86400)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompts      Prompt[]
  members      WorkspaceMember[]
  cacheMetrics CacheMetric[]

  @@unique([userId, name])
  @@index([userId])
}

model WorkspaceMember {
  id          String        @id @default(uuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(viewer)
  invitedById String?
  invitedAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  inviter   User?     @relation("WorkspaceInviter", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Prompt {
  id           String    @id @default(uuid())
  title        String
  description  String?
  content      String
  language     Language  @default(pt)
  model        String
  isPublic     Boolean   @default(false)
  isTemplate   Boolean   @default(false)
  isFavorite   Boolean   @default(false)
  forkCount    Int       @default(0)
  forkedFromId String?
  userId       String
  workspaceId  String?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace  Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  versions   PromptVersion[]
  tags       PromptTag[]
  variables  TemplateVariable[]
  executions Execution[]
  experimentsAsA PromptExperiment[] @relation("PromptExperimentA")
  experimentsAsB PromptExperiment[] @relation("PromptExperimentB")
  forkedFrom Prompt?            @relation("PromptFork", fields: [forkedFromId], references: [id], onDelete: SetNull)
  forks      Prompt[]           @relation("PromptFork")
  comments   Comment[]
  datasetRuns DatasetRun[]

  @@index([userId, deletedAt, updatedAt])
  @@index([workspaceId])
}

model PromptVersion {
  id            String   @id @default(uuid())
  versionNumber Int
  content       String
  promptId      String
  createdAt     DateTime @default(now())

  prompt     Prompt      @relation(fields: [promptId], references: [id], onDelete: Cascade)
  executions Execution[]

  @@unique([promptId, versionNumber])
  @@index([promptId, createdAt])
}

model Tag {
  id        String   @id @default(uuid())
  name      String
  slug      String
  color     String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompts PromptTag[]

  @@unique([userId, slug])
  @@index([userId])
}

model PromptTag {
  promptId String
  tagId    String

  prompt Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([promptId, tagId])
}

model TemplateVariable {
  id           String       @id @default(uuid())
  name         String
  type         VariableType @default(text)
  defaultValue String?
  options      Json?
  description  String?
  promptId     String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  prompt Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@index([promptId])
}

model Execution {
  id              String   @id @default(uuid())
  provider        ProviderType @default(openai)
  input           String
  output          String
  model           String
  credentialId    String?
  temperature     Float
  maxTokens       Int
  inputTokens     Int
  outputTokens    Int
  totalTokens     Int
  latencyMs       Int
  estimatedCost   Decimal  @db.Decimal(10, 6)
  variables       Json?
  promptId        String
  promptVersionId String
  userId          String
  datasetRunId    String?
  fromCache       Boolean       @default(false)
  cacheKey        String?
  createdAt       DateTime @default(now())

  prompt        Prompt        @relation(fields: [promptId], references: [id], onDelete: Cascade)
  promptVersion PromptVersion @relation(fields: [promptVersionId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  credential    ProviderCredential? @relation(fields: [credentialId], references: [id], onDelete: SetNull)
  experimentExposure PromptExperimentExposure?
  datasetRun    DatasetRun?   @relation(fields: [datasetRunId], references: [id], onDelete: SetNull)
  evaluations   ExecutionEvaluation[]

  @@index([userId, createdAt])
  @@index([promptId, createdAt])
  @@index([model, createdAt])
  @@index([provider, model, createdAt])
  @@index([datasetRunId])
  @@index([fromCache, createdAt])
}

model CacheMetric {
  id           String    @id @default(uuid())
  userId       String
  workspaceId  String?
  periodStart  DateTime
  periodEnd    DateTime
  hits         Int       @default(0)
  misses       Int       @default(0)
  savedCost    Decimal   @default(0) @db.Decimal(10, 6)
  savedTokens  Int       @default(0)
  createdAt    DateTime  @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId, periodStart])
  @@index([workspaceId, periodStart])
}

model PromptExperiment {
  id               String           @id @default(uuid())
  userId           String
  promptAId        String
  promptBId        String
  trafficSplitA    Int              @default(50)
  status           ExperimentStatus @default(running)
  sampleSizeTarget Int?
  startedAt        DateTime         @default(now())
  endedAt          DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  promptA   Prompt @relation("PromptExperimentA", fields: [promptAId], references: [id], onDelete: Cascade)
  promptB   Prompt @relation("PromptExperimentB", fields: [promptBId], references: [id], onDelete: Cascade)
  exposures PromptExperimentExposure[]
  votes     PromptExperimentVote[]

  @@index([userId, status, createdAt])
  @@index([promptAId])
  @@index([promptBId])
}

model PromptExperimentExposure {
  id            String            @id @default(uuid())
  experimentId  String
  requestId     String
  chosenVariant ExperimentVariant
  executionId   String            @unique
  createdAt     DateTime          @default(now())

  experiment PromptExperiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  execution  Execution        @relation(fields: [executionId], references: [id], onDelete: Cascade)
  vote       PromptExperimentVote?

  @@index([experimentId, createdAt])
  @@index([experimentId, chosenVariant, createdAt])
}

model PromptExperimentVote {
  id            String            @id @default(uuid())
  experimentId  String
  exposureId    String            @unique
  winnerVariant ExperimentVariant
  createdAt     DateTime          @default(now())

  experiment PromptExperiment         @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  exposure   PromptExperimentExposure @relation(fields: [exposureId], references: [id], onDelete: Cascade)

  @@index([experimentId, winnerVariant, createdAt])
}

model RefreshTokenSession {
  id               String   @id @default(uuid())
  tokenHash        String
  familyId         String
  parentTokenId    String?
  revokedAt        DateTime?
  createdAt        DateTime @default(now())
  expiresAt        DateTime
  userId           String

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent           RefreshTokenSession? @relation("RefreshTokenParent", fields: [parentTokenId], references: [id], onDelete: SetNull)
  children         RefreshTokenSession[] @relation("RefreshTokenParent")

  @@index([userId, familyId])
  @@index([expiresAt])
}

model ProviderCredential {
  id             String       @id @default(uuid())
  userId         String
  provider       ProviderType
  label          String?
  apiKeyEnc      String
  baseUrl        String?
  organizationId String?
  isDefault      Boolean      @default(false)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  executions     Execution[]

  @@index([userId, provider, isActive])
}

model ProviderModelPricing {
  id              String       @id @default(uuid())
  provider        ProviderType
  model           String
  inputCostPer1k  Decimal      @db.Decimal(10, 6)
  outputCostPer1k Decimal      @db.Decimal(10, 6)
  currency        String       @default("USD")
  isActive        Boolean      @default(true)
  effectiveFrom   DateTime     @default(now())
  effectiveTo     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([provider, model, isActive])
  @@index([effectiveFrom, effectiveTo])
}

model Subscription {
  id                     String             @id @default(uuid())
  userId                 String             @unique
  stripeCustomerId     String?            @unique
  stripePriceId          String?
  stripeSubscriptionId   String?            @unique
  status                 SubscriptionStatus @default(active)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  tier                   SubscriptionTier   @default(free)
  usageLimitExecutions   Int                @default(50000)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageMetric {
  id          String   @id @default(uuid())
  userId      String
  metricType  String
  value       Int
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, periodStart])
}

model Invoice {
  id               String   @id @default(uuid())
  userId           String
  stripeInvoiceId  String   @unique
  amountDue        Int
  currency         String   @default("usd")
  status           String
  hostedInvoiceUrl String?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Dataset {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  schema      Json?
  rowCount    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  rows DatasetRow[]
  runs DatasetRun[]

  @@index([userId])
}

model DatasetRow {
  id             String  @id @default(uuid())
  datasetId      String
  rowIndex       Int
  variables      Json
  expectedOutput String?

  dataset Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@unique([datasetId, rowIndex])
}

model DatasetRun {
  id          String           @id @default(uuid())
  datasetId   String
  promptId    String
  status      DatasetRunStatus @default(pending)
  completedAt DateTime?
  results     Json?
  createdAt   DateTime         @default(now())

  dataset    Dataset     @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  prompt     Prompt      @relation(fields: [promptId], references: [id], onDelete: Cascade)
  executions Execution[]

  @@index([datasetId, createdAt])
}

model EvaluationCriteria {
  id          String @id @default(uuid())
  userId      String
  name        String
  description String?
  prompt      String
  scoreMin    Int    @default(1)
  scoreMax    Int    @default(10)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluations  ExecutionEvaluation[]

  @@index([userId])
}

model ExecutionEvaluation {
  id          String   @id @default(uuid())
  executionId String
  criteriaId  String
  score       Float
  reasoning   String?
  judgeModel  String
  createdAt   DateTime @default(now())

  execution Execution           @relation(fields: [executionId], references: [id], onDelete: Cascade)
  criteria  EvaluationCriteria @relation(fields: [criteriaId], references: [id], onDelete: Cascade)

  @@index([executionId])
}

model AuditLog {
  id        String      @id @default(uuid())
  userId    String?
  action    AuditAction
  resource  String
  metadata  Json?
  ipAddress String?
  userAgent String?
  timestamp DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, timestamp])
  @@index([resource, timestamp])
}

model Webhook {
  id              String    @id @default(uuid())
  userId          String
  name            String?
  url             String
  events          String[]
  secret          String
  isActive        Boolean   @default(true)
  filters         Json?
  retryCount      Int       @default(3)
  timeoutMs       Int       @default(60000)
  lastTriggeredAt DateTime?
  failureCount    Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries  WebhookDelivery[]

  @@index([userId])
}

model WebhookDelivery {
  id             String    @id @default(uuid())
  webhookId      String
  event          String
  payload        Json
  statusCode     Int?
  responseBody   String?
  requestHeaders Json?
  errorMessage   String?
  attempts       Int       @default(1)
  deliveredAt    DateTime?
  createdAt      DateTime  @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, createdAt])
}

model PlatformApiKey {
  id         String    @id @default(uuid())
  userId     String
  label      String?
  keyHash    String
  keyPrefix  String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyPrefix])
}

model TraceRun {
  id        String   @id @default(uuid())
  userId    String
  name      String?
  source    String   @default("langchain")
  createdAt DateTime @default(now())

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  spans TraceSpan[]

  @@index([userId, createdAt])
}

model TraceSpan {
  id         String   @id @default(uuid())
  traceRunId String
  parentId   String?
  name       String
  startTime  DateTime
  endTime    DateTime?
  attributes Json?

  traceRun TraceRun  @relation(fields: [traceRunId], references: [id], onDelete: Cascade)
  parent   TraceSpan? @relation("SpanHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children TraceSpan[] @relation("SpanHierarchy")

  @@index([traceRunId])
}

model Comment {
  id        String   @id @default(uuid())
  promptId  String
  userId    String
  content   String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prompt   Prompt    @relation(fields: [promptId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Comment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentThread")
  mentions UserMention[]

  @@index([promptId, createdAt])
}

model UserMention {
  id        String @id @default(uuid())
  commentId String
  userId    String

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
}
