```typescript
/**
 * Configuration options for API initialization.
 *
 * @interface ApiConfig
 * @property {string} baseUrl - Base URL for API requests
 * @property {number} timeout - Request timeout in milliseconds (default: 5000)
 * @property {Object} headers - Custom HTTP headers
 * @property {boolean} [retry] - Whether to retry failed requests (optional)
 * @property {number} [retryCount=3] - Number of retry attempts
 */
interface ApiConfig {
  baseUrl: string;
  timeout: number;
  headers: Record<string, string>;
  retry?: boolean;
  retryCount?: number;
}

/**
 * Generic result type for operations that can succeed or fail.
 *
 * @typedef {Object} Result
 * @property {boolean} success - Indicates if operation succeeded
 * @property {T} [data] - Returned data (only if success = true)
 * @property {string} [error] - Error message (only if success = false)
 * @property {ErrorCode} [errorCode] - Machine-readable error code
 * @template T - Type of returned data
 *
 * @example
 * const result: Result<User> = await createUser(userData);
 * if (result.success) {
 *   console.log('User created:', result.data);
 * } else {
 *   console.error('Error:', result.error);
 * }
 */
type Result<T> = {
  success: boolean;
  data?: T;
  error?: string;
  errorCode?: ErrorCode;
};

/**
 * Pagination metadata for list responses.
 *
 * @typedef {Object} PaginationMeta
 * @property {number} page - Current page number (1-indexed)
 * @property {number} limit - Items per page
 * @property {number} total - Total number of items
 * @property {number} totalPages - Total number of pages
 * @property {boolean} hasNext - Whether there's a next page
 * @property {boolean} hasPrev - Whether there's a previous page
 */
type PaginationMeta = {
  page: number;
  limit: number;
  total: number;
  totalPages: number;
  hasNext: boolean;
  hasPrev: boolean;
};
