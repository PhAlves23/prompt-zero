/**
 * Fetches user data by ID from the database.
 *
 * @param {string} userId - The unique user identifier
 * @returns {Promise<User>} A promise that resolves with the user data
 * @throws {NotFoundError} When the user is not found
 * @throws {DatabaseError} When there's a database connection error
 *
 * @example
 * try {
 *   const user = await fetchUserById('user-123');
 *   console.log(user.name);
 * } catch (error) {
 *   console.error('Error fetching user:', error);
 * }
 */
async function fetchUserById(userId: string): Promise<User> {
  const user = await db.users.findOne({ id: userId });
  if (!user) {
    throw new NotFoundError(`User ${userId} not found`);
  }
  return user;
}
