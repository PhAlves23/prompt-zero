### Funções com Callbacks

```typescript
/**
 * Processes an array of items using a transformation function.
 *
 * @param {T[]} items - Array of items to process
 * @param {(item: T, index: number) => R} transform - Transformation function
 * @returns {R[]} Array of transformed items
 * @template T - Input item type
 * @template R - Output item type
 *
 * @example
 * const numbers = [1, 2, 3, 4, 5];
 * const doubled = processItems(numbers, (n) => n * 2);
 * // doubled = [2, 4, 6, 8, 10]
 *
 * @example
 * const users = [{ name: 'John' }, { name: 'Jane' }];
 * const names = processItems(users, (u) => u.name);
 * // names = ['John', 'Jane']
 */
function processItems<T, R>(
  items: T[],
  transform: (item: T, index: number) => R,
): R[] {
  return items.map(transform);
}

/**
 * Filters array based on async predicate function.
 *
 * @param {T[]} items - Array to filter
 * @param {(item: T) => Promise<boolean>} predicate - Async filter function
 * @returns {Promise<T[]>} Filtered array
 * @template T - Item type
 *
 * @example
 * const users = await asyncFilter(allUsers, async (user) => {
 *   const hasPermission = await checkPermission(user.id);
 *   return hasPermission;
 * });
 */
async function asyncFilter<T>(
  items: T[],
  predicate: (item: T) => Promise<boolean>,
): Promise<T[]> {
  const results = await Promise.all(items.map(predicate));
  return items.filter((_, index) => results[index]);
}
