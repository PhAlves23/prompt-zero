### React Components

```typescript
/**
 * Props for the Button component.
 *
 * @interface ButtonProps
 * @property {string} label - Button text label
 * @property {'primary' | 'secondary' | 'danger' | 'ghost'} [variant='primary'] - Visual variant
 * @property {'small' | 'medium' | 'large'} [size='medium'] - Button size
 * @property {boolean} [disabled=false] - Whether button is disabled
 * @property {boolean} [loading=false] - Whether button is in loading state
 * @property {() => void} [onClick] - Click event handler
 * @property {React.ReactNode} [children] - Additional button content
 * @property {string} [className] - Additional CSS classes
 * @property {string} [testId] - Test identifier for automated tests
 */
interface ButtonProps {
  label: string;
  variant?: 'primary' | 'secondary' | 'danger' | 'ghost';
  size?: 'small' | 'medium' | 'large';
  disabled?: boolean;
  loading?: boolean;
  onClick?: () => void;
  children?: React.ReactNode;
  className?: string;
  testId?: string;
}

/**
 * Reusable button component with multiple variants and loading state.
 *
 * @component
 * @param {ButtonProps} props - Component props
 * @returns {JSX.Element} Rendered button element
 *
 * @example
 * // Primary button
 * <Button
 *   label="Save Changes"
 *   variant="primary"
 *   onClick={() => saveData()}
 * />
 *
 * @example
 * // Loading state
 * <Button
 *   label="Processing..."
 *   loading={isSubmitting}
 *   disabled={isSubmitting}
 * />
 *
 * @example
 * // With children
 * <Button variant="ghost">
 *   <Icon name="trash" />
 *   Delete
 * </Button>
 */
export const Button: React.FC<ButtonProps> = ({
  label,
  variant = 'primary',
  size = 'medium',
  disabled = false,
  loading = false,
  onClick,
  children,
  className = '',
  testId,
}) => {
  return (
    <button
      className={`btn btn-${variant} btn-${size} ${className}`}
      disabled={disabled || loading}
      onClick={onClick}
      data-testid={testId}
      aria-busy={loading}
    >
      {loading && <Spinner size="small" />}
      {label}
      {children}
    </button>
  );
};
```

### Hooks Customizados

```typescript
/**
 * Hook for fetching and caching user data with automatic refetching.
 *
 * @param {string} userId - User ID to fetch
 * @param {Object} [options] - Hook options
 * @param {boolean} [options.enabled=true] - Whether to fetch automatically
 * @param {number} [options.refetchInterval] - Refetch interval in ms
 * @returns {Object} Hook state and methods
 * @returns {User | null} return.data - User data
 * @returns {boolean} return.loading - Loading state
 * @returns {Error | null} return.error - Error if occurred
 * @returns {() => void} return.refetch - Manual refetch function
 *
 * @example
 * // Basic usage
 * const { data, loading, error } = useUser('user-123');
 * if (loading) return <Spinner />;
 * if (error) return <Error message={error.message} />;
 * return <UserProfile user={data} />;
 *
 * @example
 * // With auto-refetch
 * const { data, refetch } = useUser('user-123', {
 *   refetchInterval: 5000 // Refetch every 5 seconds
 * });
 *
 * @example
 * // Conditional fetching
 * const { data } = useUser(userId, {
 *   enabled: !!userId // Only fetch if userId exists
 * });
 */
function useUser(
  userId: string,
  options?: {
    enabled?: boolean;
    refetchInterval?: number;
  },
) {
  const [data, setData] = useState<User | null>(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<Error | null>(null);

  const fetchUser = useCallback(async () => {
    try {
      setLoading(true);
      const user = await fetchUserById(userId);
      setData(user);
      setError(null);
    } catch (err) {
      setError(err as Error);
      setData(null);
    } finally {
      setLoading(false);
    }
  }, [userId]);

  useEffect(() => {
    if (options?.enabled !== false) {
      fetchUser();
    }
  }, [fetchUser, options?.enabled]);

  useEffect(() => {
    if (options?.refetchInterval) {
      const interval = setInterval(fetchUser, options.refetchInterval);
      return () => clearInterval(interval);
    }
  }, [fetchUser, options?.refetchInterval]);

  return { data, loading, error, refetch: fetchUser };
}

/**
 * Hook for managing form state with validation.
 *
 * @template T - Form values type
 * @param {T} initialValues - Initial form values
 * @param {(values: T) => Record<string, string>} [validate] - Validation function
 * @returns {Object} Form state and handlers
 *
 * @example
 * const { values, errors, handleChange, handleSubmit } = useForm({
 *   email: '',
 *   password: ''
 * }, (vals) => {
 *   const errs = {};
 *   if (!vals.email) errs.email = 'Email is required';
 *   if (!vals.password) errs.password = 'Password is required';
 *   return errs;
 * });
 */
function useForm<T extends Record<string, any>>(
  initialValues: T,
  validate?: (values: T) => Record<string, string>,
) {
  const [values, setValues] = useState<T>(initialValues);
  const [errors, setErrors] = useState<Record<string, string>>({});

  const handleChange = (name: keyof T, value: any) => {
    setValues((prev) => ({ ...prev, [name]: value }));
  };

  const handleSubmit = (onSubmit: (values: T) => void) => {
    return (e: React.FormEvent) => {
      e.preventDefault();
      const validationErrors = validate ? validate(values) : {};
      setErrors(validationErrors);
      if (Object.keys(validationErrors).length === 0) {
        onSubmit(values);
      }
    };
  };

  return { values, errors, handleChange, handleSubmit, setValues };
}
```

### Higher-Order Functions e Decorators

```typescript
/**
 * Memoizes function results based on arguments.
 *
 * @param {Function} fn - Function to memoize
 * @param {(args: any[]) => string} [keyFn] - Custom cache key generator
 * @returns {Function} Memoized function
 * @template T - Function type
 *
 * @example
 * const expensiveCalculation = memoize((n: number) => {
 *   console.log('Calculating...');
 *   return n * n;
 * });
 *
 * expensiveCalculation(5); // Logs "Calculating...", returns 25
 * expensiveCalculation(5); // Returns 25 (cached, no log)
 */
function memoize<T extends (...args: any[]) => any>(
  fn: T,
  keyFn?: (args: Parameters<T>) => string,
): T {
  const cache = new Map<string, ReturnType<T>>();

  return ((...args: Parameters<T>): ReturnType<T> => {
    const key = keyFn ? keyFn(args) : JSON.stringify(args);

    if (cache.has(key)) {
      return cache.get(key)!;
    }

    const result = fn(...args);
    cache.set(key, result);
    return result;
  }) as T;
}

/**
 * Debounces function execution.
 *
 * @param {Function} fn - Function to debounce
 * @param {number} delay - Delay in milliseconds
 * @returns {Function} Debounced function
 * @template T - Function type
 *
 * @example
 * const searchAPI = debounce((query: string) => {
 *   fetch(`/api/search?q=${query}`);
 * }, 300);
 *
 * // Only calls API after user stops typing for 300ms
 * searchInput.addEventListener('input', (e) => searchAPI(e.target.value));
 */
function debounce<T extends (...args: any[]) => any>(
  fn: T,
  delay: number,
): (...args: Parameters<T>) => void {
  let timeoutId: NodeJS.Timeout;

  return (...args: Parameters<T>) => {
    clearTimeout(timeoutId);
    timeoutId = setTimeout(() => fn(...args), delay);
  };
}

/**
 * Throttles function execution to run at most once per interval.
 *
 * @param {Function} fn - Function to throttle
 * @param {number} interval - Minimum interval between calls in ms
 * @returns {Function} Throttled function
 * @template T - Function type
 *
 * @example
 * const handleScroll = throttle(() => {
 *   console.log('Scroll position:', window.scrollY);
 * }, 100);
 *
 * window.addEventListener('scroll', handleScroll);
 */
function throttle<T extends (...args: any[]) => any>(
  fn: T,
  interval: number,
): (...args: Parameters<T>) => void {
  let lastCall = 0;

  return (...args: Parameters<T>) => {
    const now = Date.now();
    if (now - lastCall >= interval) {
      lastCall = now;
      fn(...args);
    }
  };
}
```

## Tags JSDoc Comuns

### Tags Obrigatórias

- `@param {type} name - description` - Parâmetros da função
- `@returns {type} description` - Valor de retorno
- `@throws {ErrorType} description` - Exceções que podem ser lançadas

### Tags Opcionais Úteis

- `@example` - Exemplos de uso
- `@see` - Referências relacionadas
- `@since` - Versão em que foi adicionado
- `@deprecated` - Indica que está deprecated
- `@todo` - Tarefas pendentes
- `@author` - Autor do código
- `@version` - Versão
- `@template` - Para generics
- `@typedef` - Para definir tipos customizados
- `@property` - Propriedades de objetos
- `@class` - Documentação de classe
- `@module` - Documentação de módulo
- `@async` - Indica função assíncrona
- `@private` - Marca como privado
- `@protected` - Marca como protegido
- `@readonly` - Marca como somente leitura

