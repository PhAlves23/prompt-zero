### Documentando Tipos de Erro

```typescript
/**
 * Base error class for application errors.
 *
 * @class AppError
 * @extends Error
 * @property {string} code - Machine-readable error code
 * @property {number} statusCode - HTTP status code
 * @property {Object} [meta] - Additional error metadata
 */
class AppError extends Error {
  constructor(
    message: string,
    public code: string,
    public statusCode: number,
    public meta?: Record<string, any>,
  ) {
    super(message);
    this.name = 'AppError';
  }
}

/**
 * Thrown when a requested resource is not found.
 *
 * @class NotFoundError
 * @extends AppError
 *
 * @example
 * throw new NotFoundError('User not found', { userId: '123' });
 */
class NotFoundError extends AppError {
  constructor(message: string, meta?: Record<string, any>) {
    super(message, 'NOT_FOUND', 404, meta);
    this.name = 'NotFoundError';
  }
}

/**
 * Thrown when validation fails.
 *
 * @class ValidationError
 * @extends AppError
 * @property {ValidationIssue[]} issues - List of validation issues
 *
 * @example
 * throw new ValidationError('Invalid input', {
 *   issues: [
 *     { field: 'email', message: 'Invalid email format' },
 *     { field: 'age', message: 'Must be 18 or older' }
 *   ]
 * });
 */
class ValidationError extends AppError {
  constructor(
    message: string,
    public issues: ValidationIssue[],
  ) {
    super(message, 'VALIDATION_ERROR', 400, { issues });
    this.name = 'ValidationError';
  }
}
