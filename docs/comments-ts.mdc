## Casos de Uso Avançados

### Documentando Funções Complexas com Business Logic

```typescript
/**
 * Calculates discounted price based on user tier and purchase volume.
 *
 * Business rules:
 * - VIP users: 15% discount on all purchases
 * - Premium users: 10% discount on purchases > $100
 * - Standard users: 5% discount on purchases > $500
 * - Bulk discount: Additional 5% for quantity > 10 items
 * - Maximum total discount: 25%
 *
 * @param {number} price - Base price per item
 * @param {number} quantity - Number of items
 * @param {UserTier} userTier - User's membership tier
 * @returns {number} Final discounted price
 * @throws {InvalidPriceError} When price is negative
 * @throws {InvalidQuantityError} When quantity is zero or negative
 *
 * @example
 * // VIP user buying 1 item at $100
 * calculateDiscount(100, 1, 'vip'); // 85 (15% discount)
 *
 * @example
 * // Premium user buying 12 items at $50 each
 * calculateDiscount(50, 12, 'premium');
 * // $600 base, 10% tier discount, 5% bulk = $510 final
 */
function calculateDiscount(
  price: number,
  quantity: number,
  userTier: UserTier,
): number {
  if (price < 0) throw new InvalidPriceError('Price cannot be negative');
  if (quantity <= 0) throw new InvalidQuantityError('Quantity must be positive');

  const basePrice = price * quantity;
  let discount = 0;

  // Apply tier-based discount
  switch (userTier) {
    case 'vip':
      discount = 0.15;
      break;
    case 'premium':
      if (basePrice > 100) discount = 0.10;
      break;
    case 'standard':
      if (basePrice > 500) discount = 0.05;
      break;
  }

  // Apply bulk discount
  if (quantity > 10) {
    discount += 0.05;
  }

  // Cap maximum discount at 25%
  discount = Math.min(discount, 0.25);

  return basePrice * (1 - discount);
}
```

